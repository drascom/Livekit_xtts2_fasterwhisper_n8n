
CAAL_HOST_IP=192.168.0.252
COMPOSE_PROJECT_NAME=geveze
DEBUG_MODE=false
# =============================================================================
# LiveKit Configuration (required by frontend)
# =============================================================================
# Public LiveKit server URL (WSS)
LIVEKIT_URL=wss://livekit.drascom.uk
LIVEKIT_INTERNAL_URL=ws://livekit:7880

# LiveKit API credentials
LIVEKIT_API_KEY=geveze-agent
LIVEKIT_API_SECRET=a-super-long-and-secure-secret-for-geveze-livekit-32-chars

# =============================================================================
# STT Configuration (Speaches - Faster-Whisper)
# =============================================================================
# URL for Speaches STT server (localhost for local dev, docker-compose overrides)
SPEACHES_URL=http://stt-service:8000
SPEACHES_PORT=8000
# Whisper model for STT (full HuggingFace name)
WHISPER_MODEL=Systran/faster-whisper-medium
# Speaches preload models (comma-separated model IDs)
SPEACHES_PRELOAD_MODELS=Systran/faster-whisper-medium

# Wait for all agent models before accepting sessions (0 = no timeout)
STT_MODEL_WAIT_TIMEOUT=0

# Speaches server port (external)


# =============================================================================
# LLM (Ollama) - remote server
# =============================================================================
OLLAMA_BASE_URL=https://ollama.drascom.uk
# Model name (ministral-3:8b recommended for tool calling + low latency. Requires Ollama 0.13.3+)
OLLAMA_MODEL=ministral-3:8b
# Disable thinking mode for lower latency (important for voice!)
OLLAMA_THINK=false
OLLAMA_TEMPERATURE=0.7
# Context window size (default 8192, increase for better tool response handling)
OLLAMA_NUM_CTX=8192
# Max conversation turns to keep in sliding window (prevents context overflow)
OLLAMA_MAX_TURNS=20

# Number of tool responses to cache for follow-up queries
TOOL_CACHE_SIZE=3

# =============================================================================
# MCP Server Configuration (n8n) - remote server
# =============================================================================
# n8n MCP endpoint URL (required for workflow tools)
N8N_MCP_URL=https://n8n.drascom.uk/mcp-server/http
N8N_BASE_URL=https://n8n.drascom.uk
# n8n MCP access token (required - get from n8n Settings > MCP Access)
N8N_MCP_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIwYTk2YThhZC04OGRjLTRiZWYtYWQwZS1kZWM1NTk0Y2MzOTEiLCJpc3MiOiJuOG4iLCJhdWQiOiJtY3Atc2VydmVyLWFwaSIsImp0aSI6IjMwYzczMDRjLWZiZTktNGFmYy04MDkxLTM4NzQyNTEwNjgzYiIsImlhdCI6MTc2NzI5ODk3M30.g7ri79jfNStdCfU740EtXertXtmxaPnY-O5fRmF2nSU

# =============================================================================
# Frontend -> Voice Agent (wake endpoint)
# =============================================================================
WEBHOOK_URL=http://voice-agent:8889

# =============================================================================
# TTS (XTTS service with OpenAI-compatible endpoint for LiveKit Agents)
# =============================================================================
TTS_SERVICE_URL=http://tts-service:8003

# Coqui XTTS Configuration
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_DEFAULT_VOICE=ayhan
XTTS_DEFAULT_LANGUAGE=en

# LiveKit agent dispatch name used by frontend and worker
NEXT_PUBLIC_AGENT_NAME=geveze-agent

# =============================================================================
# Wake Word Detection (Picovoice Porcupine)
# =============================================================================
# Get your access key from https://console.picovoice.ai/
# Leave empty to disable wake word feature
# Also requires hey_cal.ppn and porcupine_params.pv in frontend/public/
PORCUPINE_ACCESS_KEY=

# =============================================================================
# General
# =============================================================================
TIMEZONE=Europe/London
# Display name spoken by CAAL (optional, defaults to "Pacific Time")
TIMEZONE_DISPLAY=UK Time
